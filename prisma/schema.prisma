generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. Core Tenant & Auth Models
// ==========================================

model Company {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  currency  String   @default("PKR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          UserCompany[]
  roles          Role[]
  accounts       Account[]
  journalEntries JournalEntry[]
  customers          Customer[]
  vendors            Vendor[]
  invoices           Invoice[]
  expenses           Expense[]
  auditLogs          AuditLog[]
  recurringInvoices  RecurringInvoice[]
  bankAccounts       BankAccount[]
  transfers          Transfer[]
  fiscalYears        FiscalYear[]
  accountingPeriods  AccountingPeriod[]
  
  unitsOfMeasure     UnitOfMeasure[]
  productCategories  ProductCategory[]
  products           Product[]
  warehouses         Warehouse[]
  warehouseStocks    WarehouseStock[]
  warehouseTransfers WarehouseTransfer[]
  stockTransactions  StockTransaction[]
  purchaseBills      PurchaseBill[]
}

// ==========================================
// 9. Accounting Periods & Fiscal Years
// ==========================================

model FiscalYear {
  id        String   @id @default(uuid())
  companyId String
  name      String   // e.g. "FY 2023-24"
  startDate DateTime
  endDate   DateTime
  status    String   @default("OPEN") // OPEN, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  periods AccountingPeriod[]

  @@index([companyId])
}

model AccountingPeriod {
  id           String   @id @default(uuid())
  companyId    String
  fiscalYearId String
  name         String   // e.g. "July 2023"
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean  @default(false)
  closedAt     DateTime?
  closedBy     String?  // User ID who closed it
  status       String   @default("OPEN") // OPEN, CLOSED, LOCKED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([fiscalYearId])
  @@index([startDate, endDate])
}

// ==========================================
// 8. Bank & Cash Management
// ==========================================

model BankAccount {
  id              String   @id @default(uuid())
  companyId       String
  glAccountId     String   // Links to GL Account (Account model)
  name            String   // e.g. "HBL Current Account"
  accountNumber   String?  // Real bank account number
  bankName        String?  // e.g. "Habib Bank Limited"
  branchName      String?
  branchCode      String?
  accountType     String   @default("BANK") // BANK, CASH, MOBILE_WALLET
  currency        String   @default("PKR")
  openingBalance  Decimal  @default(0)
  currentBalance  Decimal  @default(0)
  isActive        Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactionsFrom  BankTransaction[] @relation("FromAccount")
  transactionsTo    BankTransaction[] @relation("ToAccount")
  transfersFrom     Transfer[]        @relation("TransferFrom")
  transfersTo       Transfer[]        @relation("TransferTo")

  @@index([companyId])
  @@index([glAccountId])
  @@index([accountType])
}

model Transfer {
  id              String   @id @default(uuid())
  companyId       String
  fromAccountId   String
  toAccountId     String
  journalEntryId  String?
  amount          Decimal
  transferDate    DateTime @default(now())
  reference       String?
  description     String
  status          String   @default("COMPLETED") // COMPLETED, VOIDED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromAccount BankAccount @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount   BankAccount @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([companyId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([transferDate])
}

model BankTransaction {
  id              String   @id @default(uuid())
  companyId       String
  bankAccountId   String
  oppositeAccountId String? // The other account in a transfer
  journalEntryId  String?
  type            String   // DEBIT, CREDIT
  category        String   // TRANSFER, PAYMENT_IN, PAYMENT_OUT, ADJUSTMENT, OPENING
  amount          Decimal
  runningBalance  Decimal  @default(0)
  transactionDate DateTime @default(now())
  description     String
  reference       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bankAccount     BankAccount  @relation("FromAccount", fields: [bankAccountId], references: [id], onDelete: Cascade)
  oppositeAccount BankAccount? @relation("ToAccount", fields: [oppositeAccountId], references: [id])

  @@index([companyId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([type])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies UserCompany[]
}

model Role {
  id          String   @id @default(uuid())
  companyId   String
  name        String // e.g. "ADMIN", "ACCOUNTANT", "MANAGER", "CASHIER"
  description String?
  permissions String // JSON string or comma-separated permissions (e.g., "invoice:create,report:view")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userCompanies UserCompany[]

  @@unique([companyId, name])
  @@index([companyId])
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([roleId])
}

// ==========================================
// 2. Chart of Accounts & General Ledger (GL)
// ==========================================

model Account {
  id          String   @id @default(uuid())
  companyId   String
  parentId    String?  // Self-relation for parent-child hierarchy
  code        String   // Account code (e.g., "1010", "4000")
  name        String
  type        String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subType     String?  // Optional sub-classification (e.g., "BANK", "CASH", "RECEIVABLE")
  description String?
  balance     Decimal  @default(0) // Cached ledger balance (Debits - Credits or Credits - Debits depending on type)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  journalLines JournalLine[]
  
  // Product GL Links
  productIncomes   Product[] @relation("ProductIncomeAccount")
  productExpenses  Product[] @relation("ProductExpenseAccount")
  productAssets    Product[] @relation("ProductAssetAccount")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
}

model JournalEntry {
  id          String   @id @default(uuid())
  companyId   String
  date        DateTime @default(now())
  reference   String? // Reference/Voucher number
  description String
  status      String   @default("POSTED") // DRAFT, POSTED, VOIDED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@unique([companyId, reference]) // Reference number unique per company
  @@index([companyId])
}

model JournalLine {
  id             String   @id @default(uuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal  @default(0) // Precise accounting Decimal representation
  credit         Decimal  @default(0) // Precise accounting Decimal representation
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// ==========================================
// 3. Contacts & Business Ledger (AR/AP)
// ==========================================

model Customer {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices           Invoice[]
  recurringInvoices  RecurringInvoice[]

  @@index([companyId])
}

model Vendor {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  balance   Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]
  purchaseBills PurchaseBill[]

  @@index([companyId])
}

// ==========================================
// 4. Invoicing & Payments Module
// ==========================================

model Invoice {
  id              String    @id @default(uuid())
  companyId       String
  customerId      String
  journalEntryId  String?   // Link to auto-posted journal entry
  invoiceNumber   String
  issueDate       DateTime
  dueDate         DateTime?
  subTotal        Decimal   @default(0)
  discountAmount  Decimal   @default(0)
  taxAmount       Decimal   @default(0)
  totalAmount     Decimal   @default(0)
  paidAmount      Decimal   @default(0)
  status            String    @default("DRAFT") // DRAFT, SENT, PARTIAL, PAID, OVERDUE, CANCELLED
  notes             String?
  overdueNotifiedAt DateTime? // When overdue notification was last flagged
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
}

model InvoiceItem {
  id             String   @id @default(uuid())
  invoiceId      String
  description    String
  quantity       Decimal  @default(1)
  unitPrice      Decimal
  discountRate   Decimal  @default(0) // Discount percentage e.g. 5.0 for 5%
  discountAmount Decimal  @default(0)
  taxRate        Decimal  @default(0) // Tax percentage e.g. 17.0 for 17%
  taxAmount      Decimal  @default(0)
  totalAmount    Decimal
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id             String   @id @default(uuid())
  companyId      String
  invoiceId      String
  journalEntryId String?  // Link to auto-posted journal entry for payment
  amount         Decimal
  paymentDate    DateTime @default(now())
  method         String   @default("CASH") // CASH, BANK, CHEQUE, ONLINE
  reference      String?  // Cheque number, transaction ref, etc.
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([companyId])
  @@index([invoiceId])
}

// ==========================================
// 5. Expenses & Bills Module
// ==========================================

model Expense {
  id               String   @id @default(uuid())
  companyId        String
  vendorId         String?  // Optional, if paid to a specific vendor
  journalEntryId   String?  // Link to auto-posted journal entry
  expenseAccountId String   // The GL Account for the expense (Debit)
  paymentAccountId String   // The GL Account for the payment (Credit)
  referenceNumber  String?  // Receipt or Bill number
  date             DateTime @default(now())
  amount           Decimal
  description      String
  status           String   @default("PAID") // PAID, PENDING, CANCELLED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor  Vendor? @relation(fields: [vendorId], references: [id])

  @@index([companyId])
  @@index([vendorId])
  @@index([status])
}

// ==========================================
// 7. Recurring Invoices
// ==========================================

model RecurringInvoice {
  id              String    @id @default(uuid())
  companyId       String
  customerId      String
  frequency       String    // WEEKLY, MONTHLY, QUARTERLY, YEARLY, CUSTOM
  intervalDays    Int?      // Custom interval in days (used when frequency=CUSTOM)
  nextIssueDate   DateTime
  endDate         DateTime? // null = indefinite
  daysDueAfter    Int       @default(30) // Net-30 payment terms
  templateItems   Json      // Line items template [{description, quantity, unitPrice, taxRate, discountRate}]
  notes           String?
  isActive        Boolean   @default(true)
  lastGeneratedAt DateTime?
  totalGenerated  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id])

  @@index([companyId])
  @@index([nextIssueDate])
  @@index([isActive])
}

// ==========================================
// 6. Audit Logging
// ==========================================

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String
  userId      String?  // Who performed the action
  action      String   // CREATE, UPDATE, DELETE, VOID, POST, LOGIN
  entity      String   // Invoice, Expense, JournalEntry, Account, etc.
  entityId    String?  // ID of the affected record
  description String   // Human-readable summary
  changes     String?  // JSON: { field: { old, new } }
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ==========================================
// 10. Products & Inventory
// ==========================================

model UnitOfMeasure {
  id        String   @id @default(uuid())
  companyId String
  name      String   // e.g., "Kilogram", "Piece", "Box"
  symbol    String   // e.g., "kg", "pcs", "box"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([companyId, name])
  @@unique([companyId, symbol])
  @@index([companyId])
}

model ProductCategory {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")
  products    Product[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([parentId])
}

model Product {
  id             String   @id @default(uuid())
  companyId      String
  name           String
  description    String?
  sku            String?
  barcode        String?
  
  categoryId     String?
  uomId          String?  // Unit of Measure
  
  type           String   @default("INVENTORY") // INVENTORY, SERVICE, NON_INVENTORY
  
  // Pricing
  costPrice      Decimal  @default(0)
  salePrice      Decimal  @default(0)
  
  // Inventory
  trackInventory Boolean  @default(false)
  currentStock   Decimal  @default(0)
  reorderPoint   Decimal  @default(0)
  
  // Accounting Linking
  incomeAccountId  String?
  expenseAccountId String?
  assetAccountId   String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category         ProductCategory? @relation(fields: [categoryId], references: [id])
  uom              UnitOfMeasure?   @relation(fields: [uomId], references: [id])
  incomeAccount    Account?         @relation("ProductIncomeAccount", fields: [incomeAccountId], references: [id])
  expenseAccount   Account?         @relation("ProductExpenseAccount", fields: [expenseAccountId], references: [id])
  assetAccount     Account?         @relation("ProductAssetAccount", fields: [assetAccountId], references: [id])
  
  @@unique([companyId, sku])
  @@index([companyId])
  @@index([categoryId])
  @@index([uomId])
  @@index([type])
  
  warehouseStocks    WarehouseStock[]
  transferItems      WarehouseTransferItem[]
  stockTransactions  StockTransaction[]
  purchaseBillItems  PurchaseBillItem[]
}

// ==========================================
// 11. Warehouse & Stock Management
// ==========================================

model Warehouse {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  location    String?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks     WarehouseStock[]
  transfersFrom WarehouseTransfer[] @relation("TransferFromWarehouse")
  transfersTo   WarehouseTransfer[] @relation("TransferToWarehouse")
  stockTransactions StockTransaction[]

  @@unique([companyId, name])
  @@index([companyId])
}

model WarehouseStock {
  id          String   @id @default(uuid())
  companyId   String
  warehouseId String
  productId   String
  quantity    Decimal  @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([companyId])
}

model WarehouseTransfer {
  id              String   @id @default(uuid())
  companyId       String
  fromWarehouseId String
  toWarehouseId   String
  transferDate    DateTime @default(now())
  reference       String?
  status          String   @default("COMPLETED") // DRAFT, COMPLETED, CANCELLED
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  items         WarehouseTransferItem[]

  @@index([companyId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model WarehouseTransferItem {
  id           String   @id @default(uuid())
  transferId   String
  productId    String
  quantity     Decimal

  transfer WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id])

  @@index([transferId])
  @@index([productId])
}

// ==========================================
// 12. Stock Transactions (Inventory Engine)
// ==========================================

model StockTransaction {
  id              String   @id @default(uuid())
  companyId       String
  warehouseId     String
  productId       String
  type            String   // STOCK_IN, STOCK_OUT, ADJUSTMENT, TRANSFER_IN, TRANSFER_OUT
  quantity        Decimal  // Positive for in, negative for out/adjustment
  previousQty     Decimal  @default(0)
  newQty          Decimal  @default(0)
  reference       String?  // Reference number (e.g., PO number, invoice number)
  sourceType      String?  // PURCHASE, SALE, ADJUSTMENT, TRANSFER, OPENING
  sourceId        String?  // ID of the source document (invoice, transfer, etc.)
  reason          String?  // Reason for adjustment
  notes           String?
  performedBy     String?  // User ID
  transactionDate DateTime @default(now())
  createdAt       DateTime @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@index([type])
  @@index([transactionDate])
  @@index([sourceType, sourceId])
}

// ==========================================
// 13. Purchase Bills (Inventory Integration)
// ==========================================

model PurchaseBill {
  id              String   @id @default(uuid())
  companyId       String
  vendorId        String?
  warehouseId     String    // Target warehouse for stock
  journalEntryId  String?   // Link to auto-posted journal entry
  billNumber      String
  billDate        DateTime  @default(now())
  dueDate         DateTime?
  subTotal        Decimal   @default(0)
  taxAmount       Decimal   @default(0)
  totalAmount     Decimal   @default(0)
  paidAmount      Decimal   @default(0)
  status          String    @default("RECEIVED") // DRAFT, RECEIVED, PAID, CANCELLED
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor   Vendor?  @relation(fields: [vendorId], references: [id])
  items    PurchaseBillItem[]

  @@unique([companyId, billNumber])
  @@index([companyId])
  @@index([vendorId])
  @@index([status])
}

model PurchaseBillItem {
  id             String   @id @default(uuid())
  billId         String
  productId      String
  description    String?
  quantity       Decimal  @default(1)
  unitCost       Decimal
  taxRate        Decimal  @default(0)
  taxAmount      Decimal  @default(0)
  totalAmount    Decimal
  createdAt      DateTime @default(now())

  bill    PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@index([billId])
  @@index([productId])
}
