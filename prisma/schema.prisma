generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                        String                     @id @default(uuid())
  name                      String
  email                     String?
  phone                     String?
  address                   String?
  currency                  String                     @default("PKR")
  taxNumber                 String?
  defaultTaxRate            Decimal                    @default(0)
  // Subscription & Trial Management
  plan                      String                     @default("TRIAL") // TRIAL, BASIC, PRO, ENTERPRISE
  subscriptionStatus        String                     @default("ACTIVE") // ACTIVE, SUSPENDED, EXPIRED
  trialEndsAt               DateTime?
  maxUsers                  Int                        @default(5)
  maxProducts               Int                        @default(500)
  suspendedReason           String?
  adminNotes                String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  accounts                  Account[]
  accountingPeriods         AccountingPeriod[]
  auditLogs                 AuditLog[]
  bankAccounts              BankAccount[]
  customers                 Customer[]
  expenses                  Expense[]
  fiscalYears               FiscalYear[]
  inventoryFifoConsumptions InventoryFifoConsumption[]
  inventoryFifoLayers       InventoryFifoLayer[]
  invoices                  Invoice[]
  journalEntries            JournalEntry[]
  products                  Product[]
  productCategories         ProductCategory[]
  purchaseBills             PurchaseBill[]
  recurringInvoices         RecurringInvoice[]
  roles                     Role[]
  stockTransactions         StockTransaction[]
  transfers                 Transfer[]
  unitsOfMeasure            UnitOfMeasure[]
  users                     UserCompany[]
  vendors                   Vendor[]
  warehouses                Warehouse[]
  warehouseStocks           WarehouseStock[]
  warehouseTransfers        WarehouseTransfer[]
  stockAdjustments          StockAdjustment[]
  stockTakes                StockTake[]
  posSessions               PosSession[]
  posHeldCarts              PosHeldCart[]
  subscriptionPayments      SubscriptionPayment[]
  quotations                Quotation[]
  purchaseOrders            PurchaseOrder[]
  taxRates                  TaxRate[]
  vouchers                  Voucher[]
  creditNotes               CreditNote[]
  debitNotes                DebitNote[]
}

model FiscalYear {
  id        String             @id @default(uuid())
  companyId String
  name      String
  startDate DateTime
  endDate   DateTime
  status    String             @default("OPEN")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  periods   AccountingPeriod[]
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AccountingPeriod {
  id           String     @id @default(uuid())
  companyId    String
  fiscalYearId String
  name         String
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean    @default(false)
  closedAt     DateTime?
  closedBy     String?
  status       String     @default("OPEN")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([fiscalYearId])
  @@index([startDate, endDate])
}

model BankAccount {
  id               String            @id @default(uuid())
  companyId        String
  glAccountId      String
  name             String
  accountNumber    String?
  bankName         String?
  branchName       String?
  branchCode       String?
  accountType      String            @default("BANK")
  currency         String            @default("PKR")
  openingBalance   Decimal           @default(0)
  currentBalance   Decimal           @default(0)
  isActive         Boolean           @default(true)
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactionsFrom BankTransaction[] @relation("FromAccount")
  transactionsTo   BankTransaction[] @relation("ToAccount")
  transfersFrom    Transfer[]        @relation("TransferFrom")
  transfersTo      Transfer[]        @relation("TransferTo")

  @@index([companyId])
  @@index([glAccountId])
  @@index([accountType])
}

model Transfer {
  id             String      @id @default(uuid())
  companyId      String
  fromAccountId  String
  toAccountId    String
  journalEntryId String?
  amount         Decimal
  transferDate   DateTime    @default(now())
  reference      String?
  description    String
  status         String      @default("COMPLETED")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  company        Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromAccount    BankAccount @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount      BankAccount @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([companyId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([transferDate])
}

model BankTransaction {
  id                String       @id @default(uuid())
  companyId         String
  bankAccountId     String
  oppositeAccountId String?
  journalEntryId    String?
  type              String
  category          String
  amount            Decimal
  runningBalance    Decimal      @default(0)
  transactionDate   DateTime     @default(now())
  description       String
  reference         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  bankAccount       BankAccount  @relation("FromAccount", fields: [bankAccountId], references: [id], onDelete: Cascade)
  oppositeAccount   BankAccount? @relation("ToAccount", fields: [oppositeAccountId], references: [id])

  @@index([companyId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([type])
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  firstName    String
  lastName     String?
  isActive     Boolean       @default(true)
  isSuperAdmin Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  companies    UserCompany[]
  activityLogs ActivityLog[]
}

model Role {
  id            String        @id @default(uuid())
  companyId     String
  name          String
  description   String?
  permissions   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userCompanies UserCompany[]

  @@unique([companyId, name])
  @@index([companyId])
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([roleId])
}

model Account {
  id              String        @id @default(uuid())
  companyId       String
  parentId        String?
  code            String
  name            String
  type            String
  subType         String?
  description     String?
  balance         Decimal       @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent          Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]     @relation("AccountHierarchy")
  journalLines    JournalLine[]
  productAssets   Product[]     @relation("ProductAssetAccount")
  productExpenses Product[]     @relation("ProductExpenseAccount")
  productIncomes  Product[]     @relation("ProductIncomeAccount")
  vouchers        Voucher[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
}

model JournalEntry {
  id          String        @id @default(uuid())
  companyId   String
  date        DateTime      @default(now())
  reference   String?
  description String
  status      String        @default("POSTED")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       JournalLine[]

  @@unique([companyId, reference])
  @@index([companyId])
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  description    String?
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
}

model Customer {
  id                String             @id @default(uuid())
  companyId         String
  name              String
  email             String?
  phone             String?
  address           String?
  loyaltyPoints     Int                @default(0)
  balance           Decimal            @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  quotations        Quotation[]
  creditNotes       CreditNote[]

  @@index([companyId])
}

model Vendor {
  id            String         @id @default(uuid())
  companyId     String
  name          String
  email         String?
  phone         String?
  address       String?
  balance       Decimal        @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  expenses      Expense[]
  purchaseBills  PurchaseBill[]
  purchaseOrders PurchaseOrder[]
  debitNotes     DebitNote[]
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Invoice {
  id                String        @id @default(uuid())
  companyId         String
  customerId        String
  journalEntryId    String?
  invoiceNumber     String
  issueDate         DateTime
  dueDate           DateTime?
  subTotal          Decimal       @default(0)
  discountAmount    Decimal       @default(0)
  taxAmount         Decimal       @default(0)
  totalAmount       Decimal       @default(0)
  paidAmount        Decimal       @default(0)
  status            String        @default("DRAFT")
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  overdueNotifiedAt DateTime?
  warehouseId       String?
  posSessionId      String?
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer      @relation(fields: [customerId], references: [id])
  items             InvoiceItem[]
  payments          Payment[]
  posSession        PosSession?   @relation(fields: [posSessionId], references: [id])
  creditNotes       CreditNote[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([posSessionId])
}

model PosSession {
  id             String    @id @default(uuid())
  companyId      String
  userId         String
  warehouseId    String
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingBalance Decimal   @default(0)
  closingBalance Decimal?
  status         String    @default("OPEN") // OPEN, CLOSED
  notes          String?
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])
  invoices       Invoice[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
}

model PosHeldCart {
  id          String   @id @default(uuid())
  companyId   String
  userId      String
  customerName String?
  cartData    Json     // Array of items
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

model InvoiceItem {
  id             String   @id @default(uuid())
  invoiceId      String
  description    String
  quantity       Decimal  @default(1)
  unitPrice      Decimal
  discountRate   Decimal  @default(0)
  discountAmount Decimal  @default(0)
  taxRate        Decimal  @default(0)
  taxAmount      Decimal  @default(0)
  totalAmount    Decimal
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  productId      String?
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id             String   @id @default(uuid())
  companyId      String
  invoiceId      String
  journalEntryId String?
  amount         Decimal
  paymentDate    DateTime @default(now())
  method         String   @default("CASH")
  reference      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  invoice        Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([companyId])
  @@index([invoiceId])
}

model Expense {
  id               String   @id @default(uuid())
  companyId        String
  vendorId         String?
  journalEntryId   String?
  expenseAccountId String
  paymentAccountId String
  referenceNumber  String?
  date             DateTime @default(now())
  amount           Decimal
  description      String
  status           String   @default("PAID")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor           Vendor?  @relation(fields: [vendorId], references: [id])

  @@index([companyId])
  @@index([vendorId])
  @@index([status])
}

model Quotation {
  id                String          @id @default(uuid())
  companyId         String
  customerId        String
  quotationNumber   String
  issueDate         DateTime
  expiryDate        DateTime?
  subTotal          Decimal         @default(0)
  discountAmount    Decimal         @default(0)
  taxAmount         Decimal         @default(0)
  totalAmount       Decimal         @default(0)
  status            String          @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer        @relation(fields: [customerId], references: [id])
  items             QuotationItem[]

  @@unique([companyId, quotationNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
}

model QuotationItem {
  id             String    @id @default(uuid())
  quotationId    String
  description    String
  quantity       Decimal   @default(1)
  unitPrice      Decimal
  discountRate   Decimal   @default(0)
  discountAmount Decimal   @default(0)
  taxRate        Decimal   @default(0)
  taxAmount      Decimal   @default(0)
  totalAmount    Decimal
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  productId      String?
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product        Product?  @relation(fields: [productId], references: [id])

  @@index([quotationId])
  @@index([productId])
}

model PurchaseOrder {
  id             String             @id @default(uuid())
  companyId      String
  vendorId       String?
  warehouseId    String
  orderNumber    String
  orderDate      DateTime           @default(now())
  expectedDate   DateTime?
  subTotal       Decimal            @default(0)
  taxAmount      Decimal            @default(0)
  totalAmount    Decimal            @default(0)
  status         String             @default("DRAFT") // DRAFT, SENT, PARTIAL, COMPLETED, CANCELLED
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor         Vendor?            @relation(fields: [vendorId], references: [id])
  items          PurchaseOrderItem[]

  @@unique([companyId, orderNumber])
  @@index([companyId])
  @@index([vendorId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  description     String?
  quantity        Decimal       @default(1)
  unitCost        Decimal
  taxRate         Decimal       @default(0)
  taxAmount       Decimal       @default(0)
  totalAmount     Decimal
  createdAt       DateTime      @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model RecurringInvoice {
  id              String    @id @default(uuid())
  companyId       String
  customerId      String
  frequency       String
  intervalDays    Int?
  nextIssueDate   DateTime
  endDate         DateTime?
  daysDueAfter    Int       @default(30)
  templateItems   Json
  notes           String?
  isActive        Boolean   @default(true)
  lastGeneratedAt DateTime?
  totalGenerated  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer        Customer  @relation(fields: [customerId], references: [id])

  @@index([companyId])
  @@index([nextIssueDate])
  @@index([isActive])
}

model AuditLog {
  id          String   @id @default(uuid())
  companyId   String
  userId      String?
  action      String
  entity      String
  entityId    String?
  description String
  changes     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model UnitOfMeasure {
  id        String    @id @default(uuid())
  companyId String
  name      String
  symbol    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@unique([companyId, symbol])
  @@index([companyId])
}

model ProductCategory {
  id          String            @id @default(uuid())
  companyId   String
  name        String
  description String?
  parentId    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  products    Product[]
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")

  @@unique([companyId, name])
  @@index([companyId])
  @@index([parentId])
}

model Product {
  id                  String                  @id @default(uuid())
  companyId           String
  name                String
  description         String?
  sku                 String?
  barcode             String?
  categoryId          String?
  uomId               String?
  type                String                  @default("INVENTORY")
  costPrice           Decimal                 @default(0)
  salePrice           Decimal                 @default(0)
  trackInventory      Boolean                 @default(false)
  currentStock        Decimal                 @default(0)
  reorderPoint        Decimal                 @default(0)
  incomeAccountId     String?
  expenseAccountId    String?
  assetAccountId      String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  inventoryFifoLayers InventoryFifoLayer[]
  invoiceItems        InvoiceItem[]
  assetAccount        Account?                @relation("ProductAssetAccount", fields: [assetAccountId], references: [id])
  category            ProductCategory?        @relation(fields: [categoryId], references: [id])
  company             Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenseAccount      Account?                @relation("ProductExpenseAccount", fields: [expenseAccountId], references: [id])
  incomeAccount       Account?                @relation("ProductIncomeAccount", fields: [incomeAccountId], references: [id])
  uom                 UnitOfMeasure?          @relation(fields: [uomId], references: [id])
  purchaseBillItems   PurchaseBillItem[]
  stockTransactions   StockTransaction[]
  warehouseStocks     WarehouseStock[]
  transferItems       WarehouseTransferItem[]
  stockAdjustments    StockAdjustment[]
  stockTakeItems      StockTakeItem[]
  quotationItems      QuotationItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  creditNoteItems     CreditNoteItem[]
  debitNoteItems      DebitNoteItem[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([categoryId])
  @@index([uomId])
  @@index([sku])
  @@index([barcode])
  @@index([type])
}

model Warehouse {
  id                  String               @id @default(uuid())
  companyId           String
  name                String
  location            String?
  status              String               @default("ACTIVE")
  description         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  inventoryFifoLayers InventoryFifoLayer[]
  stockTransactions   StockTransaction[]
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks              WarehouseStock[]
  transfersFrom       WarehouseTransfer[]  @relation("TransferFromWarehouse")
  transfersTo         WarehouseTransfer[]  @relation("TransferToWarehouse")
  stockAdjustments    StockAdjustment[]
  stockTakes          StockTake[]
  posSessions         PosSession[]

  @@unique([companyId, name])
  @@index([companyId])
}

model WarehouseStock {
  id          String    @id @default(uuid())
  companyId   String
  warehouseId String
  productId   String
  quantity    Decimal   @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([companyId])
}

model WarehouseTransfer {
  id              String                  @id @default(uuid())
  companyId       String
  fromWarehouseId String
  toWarehouseId   String
  transferDate    DateTime                @default(now())
  reference       String?
  status          String                  @default("COMPLETED")
  notes           String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouse   Warehouse               @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse               @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  items           WarehouseTransferItem[]

  @@index([companyId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model WarehouseTransferItem {
  id         String            @id @default(uuid())
  transferId String
  productId  String
  quantity   Decimal
  product    Product           @relation(fields: [productId], references: [id])
  transfer   WarehouseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([productId])
}

model StockTransaction {
  id              String    @id @default(uuid())
  companyId       String
  warehouseId     String
  productId       String
  type            String
  quantity        Decimal
  previousQty     Decimal   @default(0)
  newQty          Decimal   @default(0)
  reference       String?
  sourceType      String?
  sourceId        String?
  reason          String?
  notes           String?
  performedBy     String?
  transactionDate DateTime  @default(now())
  createdAt       DateTime  @default(now())
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@index([type])
  @@index([transactionDate])
  @@index([sourceType, sourceId])
}

model PurchaseBill {
  id             String             @id @default(uuid())
  companyId      String
  vendorId       String?
  warehouseId    String
  journalEntryId String?
  billNumber     String
  billDate       DateTime           @default(now())
  dueDate        DateTime?
  subTotal       Decimal            @default(0)
  taxAmount      Decimal            @default(0)
  totalAmount    Decimal            @default(0)
  paidAmount     Decimal            @default(0)
  status         String             @default("RECEIVED")
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor         Vendor?            @relation(fields: [vendorId], references: [id])
  items          PurchaseBillItem[]
  debitNotes     DebitNote[]

  @@unique([companyId, billNumber])
  @@index([companyId])
  @@index([vendorId])
  @@index([status])
}

model PurchaseBillItem {
  id          String       @id @default(uuid())
  billId      String
  productId   String
  description String?
  quantity    Decimal      @default(1)
  unitCost    Decimal
  taxRate     Decimal      @default(0)
  taxAmount   Decimal      @default(0)
  totalAmount Decimal
  createdAt   DateTime     @default(now())
  bill        PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])

  @@index([billId])
  @@index([productId])
}

model InventoryFifoLayer {
  id           String                     @id @default(uuid())
  companyId    String
  warehouseId  String
  productId    String
  unitCost     Decimal
  originalQty  Decimal
  remainingQty Decimal
  sourceType   String?
  sourceId     String?
  acquiredAt   DateTime                   @default(now())
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  consumptions InventoryFifoConsumption[]
  company      Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product      Product                    @relation(fields: [productId], references: [id])
  warehouse    Warehouse                  @relation(fields: [warehouseId], references: [id])

  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@index([remainingQty])
  @@index([acquiredAt])
}

model InventoryFifoConsumption {
  id               String             @id @default(uuid())
  companyId        String
  fifoLayerId      String
  transactionType  String
  transactionId    String
  quantityConsumed Decimal
  unitCost         Decimal
  totalCost        Decimal
  consumedAt       DateTime           @default(now())
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  layer            InventoryFifoLayer @relation(fields: [fifoLayerId], references: [id])

  @@index([companyId])
  @@index([fifoLayerId])
  @@index([transactionType, transactionId])
}

model StockAdjustment {
  id               String   @id @default(uuid())
  companyId        String
  warehouseId      String
  productId        String
  type             String   // INCREASE, DECREASE
  quantity         Decimal
  reason           String   // DAMAGED, LOST, FOUND, CORRECTION, EXPIRED
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reference        String?
  notes            String?
  performedBy      String?
  approvedBy       String?
  adjustmentDate   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id])
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  stockTakeItemId  String?  @unique

  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@index([status])
}

model StockTake {
  id             String          @id @default(uuid())
  companyId      String
  warehouseId    String
  status         String          @default("DRAFT") // DRAFT, COMPLETED, CANCELLED
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  notes          String?
  performedBy    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  items          StockTakeItem[]

  @@index([companyId])
  @@index([warehouseId])
  @@index([status])
}

model StockTakeItem {
  id               String   @id @default(uuid())
  stockTakeId      String
  productId        String
  systemQuantity   Decimal
  physicalQuantity Decimal
  discrepancy      Decimal
  notes            String?
  product          Product  @relation(fields: [productId], references: [id])
  stockTake        StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)

  @@index([stockTakeId])
  @@index([productId])
}

// ── Activity Log (Super Admin Monitoring) ──────────────────────────────
model ActivityLog {
  id          String   @id @default(uuid())
  action      String   // LOGIN, LOGOUT, COMPANY_DELETE, TRIAL_EXTEND, USER_BLOCK, PASSWORD_RESET, IMPERSONATE, PLAN_CHANGE, SUSPEND, ACTIVATE
  entityType  String?  // Company, User, etc.
  entityId    String?
  description String
  ipAddress   String?
  userAgent   String?
  performedBy String?
  user        User?    @relation(fields: [performedBy], references: [id])
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([performedBy])
  @@index([createdAt])
}

// ── Subscription Payments (Phase 4 - Billing) ─────────────────────────
model SubscriptionPayment {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  amount        Decimal
  currency      String   @default("PKR")
  method        String   // CASH, BANK_TRANSFER, JAZZCASH, EASYPAISA, CARD
  plan          String   // BASIC, PRO, ENTERPRISE
  months        Int      @default(1) // duration in months
  reference     String?  // transaction reference/receipt number
  notes         String?
  recordedBy    String?  // super admin who recorded this
  status        String   @default("COMPLETED") // COMPLETED, PENDING, REFUNDED
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
}

// ── Coupon Codes (Phase 4 - Discounts) ────────────────────────────────
model CouponCode {
  id            String    @id @default(uuid())
  code          String    @unique
  discountType  String    // PERCENTAGE, FIXED
  discountValue Decimal
  maxUses       Int       @default(1)
  usedCount     Int       @default(0)
  validFrom     DateTime  @default(now())
  validUntil    DateTime?
  applicablePlan String?  // null = all plans
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([code])
}

// ── Announcements (Phase 5 - Communication) ───────────────────────────
model Announcement {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, URGENT
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([isActive])
}

// ── Phase 2 Additions (Tax Management & Vouchers) ───────────────────────────
model TaxRate {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  rate        Decimal  // e.g., 18.00
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
}

model Voucher {
  id               String   @id @default(uuid())
  companyId        String
  voucherNumber    String
  type             String   // RECEIPT, PAYMENT
  date             DateTime @default(now())
  contactType      String?  // CUSTOMER, VENDOR
  contactId        String?  
  accountId        String   // Bank/Cash account receiving/paying
  amount           Decimal
  reference        String?
  description      String
  journalEntryId   String?  
  status           String   @default("POSTED") // POSTED, CANCELLED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account          Account  @relation(fields: [accountId], references: [id])

  @@unique([companyId, voucherNumber])
  @@index([companyId])
  @@index([type])
  @@index([date])
}

// ── Phase 3: Returns Management (Credit Notes / Debit Notes) ────────────────
model CreditNote {
  id               String           @id @default(uuid())
  companyId        String
  customerId       String
  invoiceId        String?
  creditNoteNumber String
  issueDate        DateTime         @default(now())
  subTotal         Decimal          @default(0)
  taxAmount        Decimal          @default(0)
  totalAmount      Decimal          @default(0)
  reason           String?
  warehouseId      String?
  status           String           @default("DRAFT") // DRAFT, POSTED, CANCELLED
  journalEntryId   String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer         Customer         @relation(fields: [customerId], references: [id])
  invoice          Invoice?         @relation(fields: [invoiceId], references: [id])
  items            CreditNoteItem[]

  @@unique([companyId, creditNoteNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
}

model CreditNoteItem {
  id             String     @id @default(uuid())
  creditNoteId   String
  productId      String?
  description    String
  quantity       Decimal    @default(1)
  unitPrice      Decimal
  taxRate        Decimal    @default(0)
  taxAmount      Decimal    @default(0)
  totalAmount    Decimal
  createdAt      DateTime   @default(now())
  creditNote     CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product        Product?   @relation(fields: [productId], references: [id])

  @@index([creditNoteId])
  @@index([productId])
}

model DebitNote {
  id              String          @id @default(uuid())
  companyId       String
  vendorId        String
  purchaseBillId  String?
  debitNoteNumber String
  issueDate       DateTime        @default(now())
  subTotal        Decimal         @default(0)
  taxAmount       Decimal         @default(0)
  totalAmount     Decimal         @default(0)
  reason          String?
  warehouseId     String?
  status          String          @default("DRAFT") // DRAFT, POSTED, CANCELLED
  journalEntryId  String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  purchaseBill    PurchaseBill?   @relation(fields: [purchaseBillId], references: [id])
  items           DebitNoteItem[]

  @@unique([companyId, debitNoteNumber])
  @@index([companyId])
  @@index([vendorId])
  @@index([purchaseBillId])
  @@index([status])
}

model DebitNoteItem {
  id            String    @id @default(uuid())
  debitNoteId   String
  productId     String?
  description   String
  quantity      Decimal   @default(1)
  unitCost      Decimal
  taxRate       Decimal   @default(0)
  taxAmount     Decimal   @default(0)
  totalAmount   Decimal
  createdAt     DateTime  @default(now())
  debitNote     DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id])

  @@index([debitNoteId])
  @@index([productId])
}
